# ── Plex ──────────────────────────────────────────────────────────────────────
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your_plex_token_here

# ── TMDB ──────────────────────────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key_here

# ── Trakt ─────────────────────────────────────────────────────────────────────
TRAKT_CLIENT_ID=your_trakt_client_id_here

# ── MDBList ───────────────────────────────────────────────────────────────────
MDBLIST_API_KEY=your_mdblist_api_key_here
# Minimum Trakt score (0-100) to pass quality gate
MDBLIST_MIN_TRAKT=70
# Minimum Rotten Tomatoes score (0-100) to pass quality gate
MDBLIST_MIN_RT=60

# ── Sonarr ────────────────────────────────────────────────────────────────────
SONARR_BASEURL=http://localhost:8989
SONARR_API_KEY=your_sonarr_api_key_here

# ── Radarr ────────────────────────────────────────────────────────────────────
RADARR_BASEURL=http://localhost:7878
RADARR_API_KEY=your_radarr_api_key_here

# ── Media paths ───────────────────────────────────────────────────────────────
# Paths to the Plex discovery libraries (dummy files live here)
DISCOVER_MOVIES_PATH=/media/discover_movies
DISCOVER_SHOWS_PATH=/media/discover_shows
# Paths to real media libraries (used to skip duplicates)
REAL_MOVIES_PATH=/media/real_movies
REAL_SHOWS_PATH=/media/real_shows
# Path to the 1-second dummy .mkv template (pre-generated, checked into repo)
TEMPLATE_FILE=assets/dummy.mkv

# ── Ingestion tuning ──────────────────────────────────────────────────────────
# Number of TMDB pages to fetch per provider (20 items/page, default 5 = 100 items)
PAGES_PER_PROVIDER=5
# JustWatch provider IDs → Plex label name
# Format: JSON object string. Default covers Netflix, Hulu, Apple TV+, Max.
# STREAMING_PROVIDERS={"8":"Discover_Netflix","15":"Discover_Hulu","350":"Discover_AppleTV","384":"Discover_Max"}
