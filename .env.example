LOG_LEVEL=INFO
TIMEZONE=America/New_York

# Plex
PLEX_URL=http://192.168.1.x:32400
PLEX_TOKEN=your_plex_token

# TMDB
TMDB_API_KEY=your_tmdb_api_key

# Trakt (required for Couchmoney recommendations)
TRAKT_CLIENT_ID=your_trakt_client_id
TRAKT_USERNAME=your_trakt_username

# Simkl (optional — enables genre browsing and trending data)
SIMKL_CLIENT_ID=your_simkl_client_id
SIMKL_FALLBACK_CLIENT_ID=fallback_simkl_client_id
SIMKL_REQUEST_DELAY=0.3

# AniList (optional — enables personalised anime recommendations)
ANILIST_USERNAME=your_anilist_username
ANILIST_RECS_PER_ENTRY=3

# TMDB quality gate (applied to streaming/trending results; Trakt/AniList items bypass this)
TMDB_MIN_VOTE_AVERAGE=6.2
TMDB_MIN_VOTE_COUNT=100

# Language exclusion — ISO 639-1 codes to drop from TMDB results (JSON list)
EXCLUDED_LANGUAGES=["hi","ta","te","ml","kn","bn","mr"]

# MDBList — used for quality gating and list management (/ingestion/simkl_lists)
MDBLIST_API_KEY=your_mdblist_api_key
MDBLIST_USERNAME=your_mdblist_username
MDBLIST_MIN_TRAKT=60
MDBLIST_MIN_RATING=60

# Media paths (must match volumes in docker-compose.yml)
DISCOVER_MOVIES_PATH=/data/discover_movies
DISCOVER_SHOWS_PATH=/data/discover_shows
KOMETA_CONFIG_PATH=/kometa-config

# Data/cache paths (persist on the /data volume to survive container restarts)
STATE_FILE=/data/state.json
SEED_CACHE_FILE=/data/seed_cache.json
SIMKL_ID_CACHE_FILE=/data/simkl_id_cache.json
SIMKL_LISTS_DB_FILE=/data/simkl_lists.db

DISCOVER_MOVIES_LIB="Movies"
DISCOVER_SHOWS_LIB ="TV Shows"

# Real Plex library names used for dedup (JSON list)
REAL_LIBS=["Movies","Anime Movies","TV Shows","Anime TV"]

# Ingestion tuning
PAGES_PER_PROVIDER=5
